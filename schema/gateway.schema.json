{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vpnrouter.invalid/schemas/gateway.toml/v1",
  "title": "vpnrouter-gateway configuration (gateway.toml), spike 0",
  "description": "Desired state for a Linux-first sing-box edge gateway. Policies are first-match-wins in file order.",
  "type": "object",
  "additionalProperties": false,
  "required": ["interfaces", "routing", "policies"],
  "properties": {
    "interfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wan", "lan", "lan_cidr"],
      "properties": {
        "wan": { "type": "string", "minLength": 1, "description": "WAN interface name, e.g. eth0" },
        "lan": { "type": "string", "minLength": 1, "description": "LAN interface name, e.g. br0" },
        "lan_cidr": { "type": "string", "description": "LAN subnet in CIDR notation, e.g. 192.168.10.0/24" }
      }
    },
    "management": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sources": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Admin host CIDRs: always routed direct, exempt from the killswitch, excluded from tun routing (SSH survives a dead tunnel)"
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["full", "split"], "description": "full: unmatched sources go through vpn; split: unmatched sources go direct" }
      }
    },
    "tun": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mtu": { "type": "integer", "minimum": 1280, "maximum": 1500, "default": 1420, "description": "sing-tun drops IP fragments; >1500 blackholes PMTUD, <1330 drops game DF-UDP" }
      }
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "description": "First-match-wins in file order: put specific policies before broad ones",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "source", "route"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,64}$" },
          "source": { "type": "string", "description": "Source CIDR this policy matches" },
          "protocol": { "enum": ["tcp", "udp"] },
          "port": { "type": "integer", "minimum": 1, "maximum": 65535, "description": "Destination port; requires protocol" },
          "route": { "enum": ["vpn", "direct", "block"] }
        },
        "dependentRequired": { "port": ["protocol"] }
      }
    },
    "dns": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["tunneled", "direct"], "default": "tunneled" }
      }
    },
    "killswitch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false, "description": "Drop vpn-routed LAN traffic toward WAN so it cannot leak when the tunnel is down" }
      }
    }
  }
}
